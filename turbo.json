{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "remoteCache": { "enabled": true },
  "globalEnv": ["ENABLE_EXPERIMENTAL_COREPACK"],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "dev:all": { "cache": false, "persistent": true },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [
        "dist/**",
        "build/**",
        "lib/**",
        ".next/**",
        "!.next/cache/**",
        "storybook-static/**",
        ".vitepress/dist/**"
      ]
    },
    "build:all": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "@kartuli/web-docs-client#build": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../pnpm-lock.yaml",
        "../../docs/**",
        "scripts/**",
        "!../../docs/kartuli-llm.txt"
      ],
      "outputs": [".vitepress/dist/**"]
    },
    "test": { "cache": true },
    "@kartuli/storybook#test": {
      "dependsOn": ["@kartuli/ui#build"],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "../../packages/ui/src/**", "../../apps/game-client/src/**"]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "**/*.json",
        "biome.json",
        "pnpm-lock.yaml"
      ]
    },
    "lint:all": {
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "**/*.json",
        "biome.json",
        "pnpm-lock.yaml"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.d.ts",
        "**/*.json",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json",
        "pnpm-lock.yaml"
      ],
      "outputs": []
    },
    "typecheck:all": {
      "dependsOn": ["^typecheck"],
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.d.ts",
        "**/*.json",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json",
        "pnpm-lock.yaml"
      ],
      "outputs": []
    },
    "preview": { "cache": false, "persistent": true }
  }
}

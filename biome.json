{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.next",
      "!**/lib",
      "!**/coverage",
      "!**/storybook-static",
      "!**/.vitepress/cache",
      "!**/.vitepress/dist",
      "!**/pnpm-lock.yaml",
      "!**/*.md",
      "!**/next-env.d.ts",
      "!generate-docs-for-llm.ts",
      "!**/diagrams/output"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  }
}
